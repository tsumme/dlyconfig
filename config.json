{
  "linkedin.com": {
    "full_name": {
      "selector": "h1.text-heading-xlarge, [class*='text-heading-xlarge'], .pv-text-details__left-panel div:first-child, h1",
      "transform": "innerText"
    },
    "titles": {
      "selector": ".text-body-medium.break-words, [class*='text-body-medium'], [data-test-id='headline'], main section div.mt2 > div",
      "transform": "innerText"
    },
    "company": {
      "selector": "a[href*='/company/']:not([href*='followers']) span[aria-hidden='true'], a[href*='/company/']:not([href*='followers'])",
      "transform": "innerText"
    },
    "university": {
      "selector": "a[href*='/school/']:not([href*='mentor']):not([href*='advising']) span[aria-hidden='true'], a[href*='/school/']:not([href*='mentor']):not([href*='advising'])",
      "transform": "innerText"
    },
    "location": {
      "selector": "span.text-body-small.inline.t-black--light.break-words, [class*='text-body-small'][class*='break-words'], div:has(> a[href*='contact-info']) span:first-child",
      "transform": "innerText"
    },
    "pic_url": {
      "selector": "img.pv-top-card-profile-picture__image--show, [class*='profile-displayphoto'], img[alt*='profile picture']",
      "transform": "src"
    },
    "idUser": {
      "selector": "[data-member-id]",
      "transform": "data-member-id"
    },
    "container": {
      "selector": "main.scaffold-layout__main, section.artdeco-card, #root"
    }
  },
  "linkedin-search": {
    "searchResult": "[data-view-name=\"people-search-result\"]",
    "nameLink": "a[data-view-name=\"search-result-lockup-title\"][href*=\"/in/\"]",
    "detailedLink": "a[href*=\"/in/\"]:not([data-view-name=\"search-result-lockup-title\"]):not([data-view-name=\"search-result-social-proof-insight\"])",
    "paragraphs": "p",
    "companyStrong": "strong"
  },
  "bing-linkedin-search": {
    "cardIndicator": "s_appgobig",
    "contextCharsBeforeCite": 1500,
    "contextCharsAfterCite": 600,
    "maxResults": 5
  },
  "mail.google.com": {
    "dom": { "selector": ".gE .iw" },
    "email": { "selector": "span[email]", "transform": "email" },
    "nameprofile": { "selector": ".gD", "transform": "innerText" }
  },
  "facebook.com": {
    "full_name": { "selector": "h1", "transform": "innerText" },
    "pic_url": { "selector": "a svg g image", "transform": "xlink:href" }
  },
  "twitter.com": {
    "full_name": { "selector": "[data-testid='UserName'] span", "transform": "innerText" },
    "pic_url": { "selector": "a[href$='/photo'] img", "transform": "src" }
  },
  "x.com": {
    "full_name": "div[data-testid='User-Name'] > div > div > a > div > div > span > span"
  },
  "version": "1.0.5"
}
