{
  "version": "1.1.19",
  "linkedin.com": {
    "extractionMode": "top_card_ordered_v5",
    "structuralTopCard": {
      "enabled": true,
      "requireOrderedFields": true,
      "requireNameHeading": true,
      "fieldOrder": [
        "full_name",
        "titles",
        "location",
        "contact_info"
      ],
      "useContactInfoBoundaryForLocation": true,
      "preferLeafTextNodes": true,
      "dropTitleWhenEqualsLocation": true,
      "dropTitleWhenEqualsName": true,
      "dropLocationContainingContactInfo": true,
      "uiChromeRejectPatterns": [
        "广告选项",
        "为什么显示此广告",
        "管理广告偏好",
        "Ad options",
        "Why am I seeing this ad",
        "Manage ad preferences",
        "Advertisement",
        "Promoted"
      ]
    },
    "container": {
      "selector": "main.scaffold-layout__main, main, #root"
    },
    "topCard": {
      "candidateSelectors": [
        "main section",
        "main div[data-view-name]",
        "main .pv-top-card",
        "main .ph5",
        "main .mt2",
        "main > div",
        "section"
      ],
      "headingSelector": "h1, h2, .text-heading-xlarge",
      "contactInfoSelector": "a[href*='/overlay/contact-info/'], a[href*='contact-info']",
      "leafTextSelector": "h1, h2, h3, p, span, div, a",
      "actionTextPattern": "^(Message|Connect|Follow|More|Save|Pending|View in Recruiter|Contact info|Open to work|Show all|View full profile)$",
      "degreePattern": "^·?\\s*(1st|2nd|3rd)\\s*$",
      "connectionPattern": "^[\\d,.\\+kKmM\\s]*(connections?|followers?|mutual)\\b",
      "titleHintPattern": "\\b(founder|co[- ]?founder|director|engineer|manager|designer|consultant|owner|partner|lead|head|president|ceo|cto|cfo|vp|product|sales|marketing|therapist|developer|analyst|architect|responsable|fondateur|associé|gestionnaire|ingénieur|directeur|chef|joaillerie|vendeur|ventes|produit|project|projec|r&d|mechanical|design|sav|pilotage)\\b|\\bchez\\b|\\bat\\b|@|\\|",
      "locationHintPattern": "\\b(greater\\s+[a-z .-]+\\s+area)\\b|\\b(metropolitan\\s+area)\\b|\\b(united states|canada|france|china|india|poland|germany|united kingdom|australia)\\b|\\b(california|new york|texas|florida|ohio|delhi|warsaw|paris|cachan|shenzhen|guangdong|mazowieckie)\\b|\\b(île-de-france|ile-de-france|greater paris|san francisco bay area)\\b|法兰西岛|法国|巴黎|卡尚|美国|俄亥俄州|哥伦布|中国|广东|深圳|地区"
    },
    "full_name": {
      "selector": "main div:has(> div h1):has(a[href*='/overlay/contact-info/']) > div h1, main div:has(> div h2):has(a[href*='/overlay/contact-info/']) > div h2, main div:has(> h1):has(a[href*='/overlay/contact-info/']) > h1, main div:has(> h2):has(a[href*='/overlay/contact-info/']) > h2, main a[href^='https://www.linkedin.com/in/'] h1, main a[href^='https://www.linkedin.com/in/'] h2, main a[href^='/in/'] h1, main a[href^='/in/'] h2, section:has(a[href*='contact-info']) a[href*='/in/'] h1, section:has(a[href*='contact-info']) a[href*='/in/'] h2, div:has(a[href*='/overlay/contact-info/']) a[href*='/in/'] h1, div:has(a[href*='/overlay/contact-info/']) a[href*='/in/'] h2, main h1.text-heading-xlarge, main h2.text-heading-xlarge, main .text-heading-xlarge, main h1, main h2",
      "transform": "innerText"
    },
    "pic_url": {
      "selector": "div[aria-label='Profile photo'] img, .pv-top-card-profile-picture__image--show, [data-testid='profile-photo'] img, img[alt*='profile'], img[class*='profile-picture'], img[class*='presence-entity__image']",
      "transform": "src"
    },
    "location": {
      "selector": "[data-view-name='profile-top-card-location']",
      "transform": "innerText",
      "fallbacks": [
        "main section:has(a[href*='/overlay/contact-info/']) [data-view-name='profile-top-card-location']",
        "main div[data-view-name='profile-top-card-location']"
      ],
      "notes": "Intentionally conservative. Do not use broad p:first-child selectors here because they can return wrapper text containing Contact info. Ordered extension logic should derive location from Contact info boundary when no clean leaf node exists."
    },
    "titles": {
      "selector": "main div:has(> div h1):has(a[href*='/overlay/contact-info/']) > div:has(h1) + p, main div:has(> div h2):has(a[href*='/overlay/contact-info/']) > div:has(h2) + p, main div:has(> h1):has(a[href*='/overlay/contact-info/']) > h1 + p, main div:has(> h2):has(a[href*='/overlay/contact-info/']) > h2 + p, div:has(> div a[href*='/in/'] h2):has(> div a[href*='/overlay/contact-info/']) > p:first-of-type, div:has(a[href*='/in/'] h2):has(a[href*='/overlay/contact-info/']) > p:first-of-type, main section h1 + p, main section h2 + p, main .text-heading-xlarge + p",
      "transform": "innerText"
    },
    "company": {
      "selector": "div[role='button']:has(svg[id*='company']) p, div[role='button']:has(svg[id*='company']) span, section[componentkey*='Topcard'] a[href*='/company/'] p",
      "transform": "innerText",
      "fallbacks": [
        "#experience ~ .pvs-list__outer-container .t-14.t-normal span[aria-hidden='true']",
        ".pv-text-details__right-panel .pv-entity__summary-info .pv-entity__secondary-title",
        ".experience-section .pv-entity__summary-info .pv-entity__secondary-title",
        ".pv-top-card--experience-list .pv-entity__secondary-title",
        ".experience-item .pv-entity__secondary-title"
      ]
    },
    "university": {
      "selector": "div[role='button']:has(svg[id*='school']) p, div[role='button']:has(svg[id*='school']) span, section[componentkey*='Topcard'] a[href*='/school/'] p",
      "transform": "innerText",
      "fallbacks": [
        "#education ~ .pvs-list__outer-container .mr1.hoverable-link-text span[aria-hidden='true']",
        ".education-section .pv-entity__degree-name",
        ".education-section .pv-entity__school-name"
      ]
    },
    "idUser": {
      "selector": "[data-member-id]",
      "transform": "data-member-id",
      "required": false,
      "reportMissing": false
    },
    "multipleCompany": {
      "selectorSpan": "[data-testid*='ExperienceTopLevelSection'] ul li > span, #experience + div + div ul li:nth-of-type(1) ul li > span",
      "selector": "a[href*='/company/'] p:first-of-type, li a[href*='/company/'] p",
      "transform": "innerText"
    },
    "routing": {
      "allowedPathPatterns": [
        "^/in/[^/]+"
      ],
      "blockedPathPatterns": [
        "^/feed",
        "^/search",
        "^/company",
        "^/mynetwork",
        "^/jobs",
        "^/messaging",
        "^/notifications",
        "^/404",
        "^/home",
        "^/learning",
        "^/events"
      ]
    }
  },
  "linkedin-search": {
    "searchResult": "[data-view-name=\"people-search-result\"], div[componentkey*=\"SearchResults_\"][componentkey*=\"people\"], li:has(a[data-view-name=\"search-result-lockup-title\"][href*=\"/in/\"])",
    "nameLink": "a[data-view-name=\"search-result-lockup-title\"][href*=\"/in/\"]",
    "detailedLink": "a[href*=\"/in/\"]:not([data-view-name=\"search-result-lockup-title\"]):not([data-view-name=\"search-result-social-proof-insight\"]):not([href*=\"miniProfileUrn\"]):not([href*=\"mutual\"])",
    "paragraphs": "p",
    "companyStrong": "strong"
  },
  "bing-linkedin-search": {
    "citeTag": "/<cite[^>]*>([\\s\\S]{0,300}?)<\\/cite>/gi",
    "h2Tag": "/<h2[^>]*>([\\s\\S]*?)<\\/h2>/i",
    "bingHrefPattern": "/href=\"(https?:\\/\\/(?:www\\.)?bing\\.com\\/ck\\/a[^\"]*|https?:\\/\\/(?:www\\.)?linkedin\\.com\\/(?:in|pub|posts)\\/[^\"]+)\"/gi",
    "linkedinInPattern": "/^(?:(?:www|[a-z]{2})\\.)?linkedin\\.com\\s*[›>\\/\\s]\\s*in\\s*[›>\\/\\s]\\s*([^\\s›>\\/]+)/i",
    "linkedinPostsPattern": "/^(?:(?:www|[a-z]{2})\\.)?linkedin\\.com\\s*[›>\\/\\s]\\s*posts\\s*[›>\\/\\s]\\s*([^_\\s›>\\/]+)/i",
    "cardIndicator": "s_appgobig",
    "contextCharsBeforeCite": 1500,
    "contextCharsAfterCite": 600,
    "maxResults": 5
  },
  "linkedin-background-search": {
    "version": "people-row-order-v2",
    "peopleMarkers": [
      "SearchResultsPeople",
      "data-sdui-screen=\"com.linkedin.sdui.flagshipnav.search.SearchResultsPeople\"",
      "SearchResults_FirstResult_people",
      "data-view-name=\"people-search-result\"",
      "search-result-lockup-title"
    ],
    "resultBlockStartPattern": "/<(?:li|div)\\b(?=[\\s\\S]{0,2500}(?:href=[\"'][^\"']*\\/in\\/|\\/in\\/))[^>]*(?:componentkey=[\"']SearchResults_[^\"']*people[^\"']*[\"']|data-view-name=[\"']people-search-result[\"']|role=[\"']listitem[\"'])[^>]*>/gi",
    "componentKeyPeoplePattern": "/componentkey=[\"']SearchResults_[^\"']*people/i",
    "profileLinkPatterns": [
      {
        "regex": "/href=[\"']([^\"']+)[\"']/gi",
        "source": "href"
      },
      {
        "regex": "/\"(?:url|navigationUrl|targetUrl)\"\\s*:\\s*\"([^\"]+)\"/gi",
        "source": "json_url"
      },
      {
        "regex": "/(https?:\\\\/\\\\/(?:www\\.)?linkedin\\.com\\\\/in\\\\/[a-z0-9%\\-_.~\\\\/?#=&]+)/gi",
        "source": "escaped_url"
      },
      {
        "regex": "/(https?:\\/\\/(?:www\\.)?linkedin\\.com\\/in\\/[a-z0-9%\\-_.~/?#=&]+)/gi",
        "source": "absolute_url"
      },
      {
        "regex": "/(\\/in\\/[a-z0-9%\\-_.~]+(?:[/?#][^\"'<>\\s]*)?)/gi",
        "source": "relative_url"
      }
    ],
    "ignoredLinkedInUrlPatterns": [
      "/\\/pub\\/dir\\//i",
      "/\\/search\\/results\\/people/i",
      "/\\/feed\\/update/i",
      "/\\/posts\\//i",
      "/[?&]trk=[^\"']*(?:mutual|social)/i"
    ],
    "authBlockedStatusCodes": [
      429,
      999
    ],
    "authBlockedUrlMarkers": [
      "/checkpoint",
      "/challenge",
      "/uas/login",
      "/login"
    ],
    "authLoggedOutUrlMarkers": [
      "authwall"
    ],
    "authLoggedOutPagePatterns": [
      "/name=[\"']pagekey[\"'][^>]*content=[\"']authwall[\"']/i",
      "/<title>\\s*linkedin login/i",
      "/<title>\\s*sign in/i"
    ],
    "authLoggedOutPageMarkers": [
      "sign in to view"
    ],
    "authBlockedPageMarkers": [
      "captcha",
      "checkpoint",
      "challenge"
    ],
    "degreePattern": "/(?:^|\\s|•)(1st|2nd|3rd\\+?|3rd)(?:\\s|$)/i",
    "currentPattern": "/Current:\\s*([\\s\\S]*?)(?=\\s+(?:Past:|Message|Connect|Follow|$))/i",
    "geographyPattern": "/\\b([A-Z][A-Za-z.'-]+(?:\\s+[A-Z][A-Za-z.'-]+){0,2},\\s*[A-Z][A-Za-z .'-]{2,40},\\s*(?:United States|Canada|United Kingdom|Australia|India|Netherlands|Germany|France|Ireland|New Zealand|Singapore))\\b/",
    "nameAnchorPattern": "/<a[^>]+href=[\"'](?:https:\\/\\/www\\.linkedin\\.com)?\\/in\\/[^\"']+[\"'][^>]*>([\\s\\S]*?)<\\/a>/i",
    "maxResultsCap": 5,
    "maxBlockSpanChars": 25000,
    "maxBlockCount": 200,
    "fallbackWindowChars": 2500
  },
