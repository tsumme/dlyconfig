{
  "version": "1.1.14",
  "linkedin.com": {
    "container": {
      "selector": "main.scaffold-layout__main, main, #root"
    },
    "full_name": {
      "selector": "main a[href^='https://www.linkedin.com/in/'] h1, main a[href^='https://www.linkedin.com/in/'] h2, main a[href^='/in/'] h1, main a[href^='/in/'] h2, section:has(a[href*='contact-info']) a[href*='/in/'] h1, section:has(a[href*='contact-info']) a[href*='/in/'] h2, div:has(a[href*='/overlay/contact-info/']) a[href*='/in/'] h1, div:has(a[href*='/overlay/contact-info/']) a[href*='/in/'] h2",
      "transform": "innerText"
    },
    "pic_url": {
      "selector": "div[aria-label='Profile photo'] img, .pv-top-card-profile-picture__image--show, [data-testid='profile-photo'] img, img[alt*='profile'], img[class*='profile-picture'], img[class*='presence-entity__image']",
      "transform": "src"
    },
    "location": {
      "selector": "div:has(> p > a[href*='/overlay/contact-info/']) > p:first-child, div:has(> p > a[href*='contact-info']) > p:first-child, [data-view-name='profile-top-card-location']",
      "transform": "innerText"
    },
    "titles": {
      "selector": "div:has(> div a[href*='/in/'] h2):has(> div a[href*='/overlay/contact-info/']) > p:first-of-type, div:has(a[href*='/in/'] h2):has(a[href*='/overlay/contact-info/']) > p:first-of-type, .text-body-medium.break-words",
      "transform": "innerText"
    },
    "company": {
      "selector": "div[role='button']:has(svg[id*='company']) p, div[role='button']:has(svg[id*='company']) span, section[componentkey*='Topcard'] a[href*='/company/'] p",
      "transform": "innerText",
      "fallbacks": [
        "#experience ~ .pvs-list__outer-container .t-14.t-normal span[aria-hidden='true']",
        ".pv-text-details__right-panel .pv-entity__summary-info .pv-entity__secondary-title",
        ".experience-section .pv-entity__summary-info .pv-entity__secondary-title",
        ".pv-top-card--experience-list .pv-entity__secondary-title",
        ".experience-item .pv-entity__secondary-title"
      ]
    },
    "university": {
      "selector": "div[role='button']:has(svg[id*='school']) p, div[role='button']:has(svg[id*='school']) span, section[componentkey*='Topcard'] a[href*='/school/'] p",
      "transform": "innerText",
      "fallbacks": [
        "#education ~ .pvs-list__outer-container .mr1.hoverable-link-text span[aria-hidden='true']",
        ".education-section .pv-entity__degree-name",
        ".education-section .pv-entity__school-name"
      ]
    },
    "idUser": {
      "selector": "[data-member-id]",
      "transform": "data-member-id",
      "required": false,
      "reportMissing": false
    },
    "multipleCompany": {
      "selectorSpan": "[data-testid*='ExperienceTopLevelSection'] ul li > span, #experience + div + div ul li:nth-of-type(1) ul li > span",
      "selector": "a[href*='/company/'] p:first-of-type, li a[href*='/company/'] p",
      "transform": "innerText"
    },
    "routing": {
      "allowedPathPatterns": [
        "^/in/[^/]+"
      ],
      "blockedPathPatterns": [
        "^/feed",
        "^/search",
        "^/company",
        "^/mynetwork",
        "^/jobs",
        "^/messaging",
        "^/notifications",
        "^/404",
        "^/home",
        "^/learning",
        "^/events"
      ]
    }
  },
  "linkedin-search": {
    "searchResult": "[data-view-name=\"people-search-result\"]",
    "nameLink": "a[data-view-name=\"search-result-lockup-title\"][href*=\"/in/\"]",
    "detailedLink": "a[href*=\"/in/\"]:not([data-view-name=\"search-result-lockup-title\"]):not([data-view-name=\"search-result-social-proof-insight\"])",
    "paragraphs": "p",
    "companyStrong": "strong"
  },
  "bing-linkedin-search": {
    "citeTag": "/<cite[^>]*>([\\s\\S]{0,300}?)<\\/cite>/gi",
    "h2Tag": "/<h2[^>]*>([\\s\\S]*?)<\\/h2>/i",
    "bingHrefPattern": "/href=\"(https?:\\/\\/(?:www\\.)?bing\\.com\\/ck\\/a[^\"]*|https?:\\/\\/(?:www\\.)?linkedin\\.com\\/(?:in|pub|posts)\\/[^\"]+)\"/gi",
    "linkedinInPattern": "/^(?:(?:www|[a-z]{2})\\.)?linkedin\\.com\\s*[›>\\/\\s]\\s*in\\s*[›>\\/\\s]\\s*([^\\s›>\\/]+)/i",
    "linkedinPostsPattern": "/^(?:(?:www|[a-z]{2})\\.)?linkedin\\.com\\s*[›>\\/\\s]\\s*posts\\s*[›>\\/\\s]\\s*([^_\\s›>\\/]+)/i",
    "cardIndicator": "s_appgobig",
    "contextCharsBeforeCite": 1500,
    "contextCharsAfterCite": 600,
    "maxResults": 5
  },
  "linkedin-background-search": {
    "version": "default-v1",
    "peopleMarkers": [
      "SearchResultsPeople",
      "data-sdui-screen=\"com.linkedin.sdui.flagshipnav.search.SearchResultsPeople\"",
      "SearchResults_FirstResult_people"
    ],
    "resultBlockStartPattern": "/<(?:li|div)\\b[^>]*(?:componentkey=[\"']SearchResults_[^\"']*people[^\"']*[\"']|role=[\"']listitem[\"'])[^>]*>/gi",
    "componentKeyPeoplePattern": "/componentkey=[\"']SearchResults_[^\"']*people/i",
    "profileLinkPatterns": [
      {
        "regex": "/href=[\"']([^\"']+)[\"']/gi",
        "source": "href"
      },
      {
        "regex": "/\"(?:url|navigationUrl|targetUrl)\"\\s*:\\s*\"([^\"]+)\"/gi",
        "source": "json_url"
      },
      {
        "regex": "/(https?:\\\\/\\\\/(?:www\\.)?linkedin\\.com\\\\/in\\\\/[a-z0-9%\\-_.~\\\\/?#=&]+)/gi",
        "source": "escaped_url"
      },
      {
        "regex": "/(https?:\\/\\/(?:www\\.)?linkedin\\.com\\/in\\/[a-z0-9%\\-_.~/?#=&]+)/gi",
        "source": "absolute_url"
      },
      {
        "regex": "/(\\/in\\/[a-z0-9%\\-_.~]+(?:[/?#][^\"'<>\\s]*)?)/gi",
        "source": "relative_url"
      }
    ],
    "ignoredLinkedInUrlPatterns": [
      "/\\/pub\\/dir\\//i",
      "/\\/search\\/results\\/people/i",
      "/\\/feed\\/update/i",
      "/\\/posts\\//i"
    ],
    "authBlockedStatusCodes": [429, 999],
    "authBlockedUrlMarkers": [
      "/checkpoint",
      "/challenge",
      "/uas/login",
      "/login"
    ],
    "authLoggedOutUrlMarkers": [
      "authwall"
    ],
    "authLoggedOutPagePatterns": [
      "/name=[\"']pagekey[\"'][^>]*content=[\"']authwall[\"']/i",
      "/<title>\\s*linkedin login/i",
      "/<title>\\s*sign in/i"
    ],
    "authLoggedOutPageMarkers": [
      "sign in to view"
    ],
    "authBlockedPageMarkers": [
      "captcha",
      "checkpoint",
      "challenge"
    ],
    "degreePattern": "/(?:^|\\s|•)(1st|2nd|3rd\\+?|3rd)(?:\\s|$)/i",
    "currentPattern": "/Current:\\s*([\\s\\S]*?)(?=\\s+(?:Past:|Message|Connect|Follow|$))/i",
    "geographyPattern": "/([A-Z][A-Za-z .'-]+,\\s*[A-Z][A-Za-z .'-]+,\\s*(?:United States|Canada|United Kingdom|Australia|India))/",
    "nameAnchorPattern": "/<a[^>]+href=[\"'](?:https:\\/\\/www\\.linkedin\\.com)?\\/in\\/[^\"']+[\"'][^>]*>([\\s\\S]*?)<\\/a>/i",
    "maxResultsCap": 5,
    "maxBlockSpanChars": 25000,
    "maxBlockCount": 200,
    "fallbackWindowChars": 2500
  },
  "mail.google.com": {
    "dom": {
      "selector": ".gE .iw"
    },
    "email": {
      "selector": "span[email]",
      "transform": "email",
      "nonHuman": {
        "additionalMailboxWords": [],
        "additionalMailboxes": [],
        "additionalDomains": [],
        "additionalAddresses": [],
        "additionalLocalPartPatterns": [],
        "additionalDisplayNameWords": []
      }
    },
    "nameprofile": {
      "selector": ".gD",
      "transform": "innerText"
    }
  },
  "facebook.com": {
    "routing": {
      "blockedPathPatterns": [
        "^/checkpoint",
        "^/content/insights",
        "^/login",
        "^/recover",
        "^/settings",
        "^/groups",
        "^/watch",
        "^/marketplace",
        "^/business",
        "^/ads",
        "^/search",
        "^/$",
        "^/home",
        "^/latest",
        "^/photo\\.php",
        "^/photos",
        "^/posts",
        "^/events_manager2",
        "^/billing_hub",
        "^/commerce",
        "^/security",
        "^/select",
        "^/invitation",
        "^/auth_platform",
        "^/dialog",
        "^/post/create"
      ]
    },
    "full_name": {
      "selector": "div[role='main'] h1, div[role='main'] h1 span[dir='auto'], span[dir='auto'] h1",
      "transform": "innerText",
      "fallbacks": [
        { "selector": "h1.html-h1", "transform": "innerText" },
        { "selector": "h1", "transform": "innerText" },
        { "selector": "meta[property='og:title']", "transform": "content" },
        { "selector": "svg[role='img'][aria-label]", "transform": "aria-label" }
      ],
      "rejectValues": [
        "Facebook",
        "Log in",
        "Sign up",
        "Checkpoint",
        "Content insights",
        "Home",
        "Watch",
        "Marketplace",
        "Groups",
        "Search results"
      ]
    },
    "pic_url": {
      "selector": "svg[role='img'][aria-label] image, svg[aria-label] image, a svg g image",
      "transform": "xlink:href",
      "fallbacks": [
        { "selector": "svg[role='img'][aria-label] image", "transform": "xlink:href" },
        { "selector": "svg[role='img'][aria-label] image", "transform": "href" },
        { "selector": "svg[aria-label] image", "transform": "xlink:href" },
        { "selector": "svg[aria-label] image", "transform": "href" },
        { "selector": "svg[aria-label] g image", "transform": "xlink:href" },
        { "selector": "svg[aria-label] g image", "transform": "href" },
        { "selector": "a[aria-label] svg image", "transform": "xlink:href" },
        { "selector": "a[aria-label] svg image", "transform": "href" },
        { "selector": "a[aria-label] svg g image", "transform": "xlink:href" },
        { "selector": "a[aria-label] svg g image", "transform": "href" },
        { "selector": "a svg image", "transform": "xlink:href" },
        { "selector": "a svg image", "transform": "href" },
        { "selector": "a svg g image", "transform": "xlink:href" },
        { "selector": "a svg g image", "transform": "href" }
      ]
    },
    "company": {
      "sectionTitle": "Work",
      "containerSelector": "h2",
      "listItemSelector": "[role='listitem']",
      "textSelector": "span[dir='auto']"
    },
    "university": {
      "sectionTitle": "Education",
      "containerSelector": "h2",
      "listItemSelector": "[role='listitem']",
      "textSelector": "span[dir='auto']"
    },
    "highlightedDetails": {
      "containerSelector": "[aria-label='Highlighted details'][role='list'], span[aria-label='Highlighted details']",
      "listItemSelector": "[role='listitem']",
      "companyLinkSelector": "a[href*='facebook.com/']",
      "textSelector": "span, a",
      "blockedHrefPathPatterns": [
        "/search",
        "/groups",
        "/events",
        "/watch",
        "/marketplace",
        "/friends",
        "/profile.php",
        "/pages",
        "/photo",
        "/videos",
        "/reels"
      ],
      "locationPattern": "^[A-Za-zÀ-ÖØ-öø-ÿ .'-]+,\\s*(?:[A-Z]{2}|[A-Za-zÀ-ÖØ-öø-ÿ ]+)(?:,\\s*[A-Za-zÀ-ÖØ-öø-ÿ .'-]+)?$",
      "schoolKeywords": [
        "University",
        "College",
        "School",
        "Institute",
        "Academy",
        "State University",
        "Community College"
      ]
    }
  },
  "twitter.com": {
    "full_name": {
      "selector": "div[data-testid='UserName'] span, div[data-testid='User-Name'] > div > div > a > div > div > span > span",
      "transform": "innerText"
    },
    "pic_url": {
      "selector": "a[href$='/photo'] img",
      "transform": "src"
    }
  }
}
