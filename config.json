      },
      {
        "regex": "/(https?:\\/\\/(?:www\\.)?linkedin\\.com\\/in\\/[a-z0-9%\\-_.~/?#=&]+)/gi",
        "source": "absolute_url"
      },
      {
        "regex": "/(\\/in\\/[a-z0-9%\\-_.~]+(?:[/?#][^\"'<>\\s]*)?)/gi",
        "source": "relative_url"
      }
    ],
    "ignoredLinkedInUrlPatterns": [
